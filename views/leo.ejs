<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VA5PD | Records & Reports</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        .paper-shadow { shadow-sm: 0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24); }
        .official-seal { opacity: 0.05; pointer-events: none; position: absolute; }
        body { font-family: 'Inter', sans-serif; }
        .pdf-font { font-family: 'Libre+Baskerville', serif; }
        .lock-blur { backdrop-filter: blur(8px); }
    </style>
</head>
<body class="bg-gray-200 min-h-screen flex flex-col" x-data="{ activeForm: 'none', view: 'entry' }">

    <header class="bg-[#1a1a1a] text-white p-3 flex justify-between items-center border-b-4 border-yellow-600 shadow-lg">
        <div class="flex items-center gap-4">
            <div class="bg-white p-1 rounded-full w-10 h-10 flex items-center justify-center">
                <span class="text-black font-black text-xs">VA5PD</span>
            </div>
            <div>
                <h1 class="font-bold text-sm tracking-widest uppercase">Department of Public Safety</h1>
                <p class="text-[10px] text-gray-400 font-mono">OFFICIAL RECORDS DIVISION // v5.0.1</p>
            </div>
        </div>
        <div class="flex items-center gap-4 text-right">
            <div class="pr-4 border-r border-gray-700">
                <p class="text-[10px] uppercase text-yellow-600 font-bold tracking-tighter">Authenticated User</p>
                <p class="text-xs font-bold uppercase"><%= user.username %></p>
            </div>
            <a href="/logout" class="text-[10px] bg-red-700 px-3 py-1 rounded hover:bg-red-600 transition-all font-bold">EXIT SYSTEM</a>
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden relative">
        
        <aside class="w-64 bg-[#2a2a2a] p-4 flex flex-col gap-2 opacity-50 pointer-events-none">
            <p class="text-[10px] text-gray-500 font-bold mb-2 uppercase tracking-widest">Administrative Tools</p>
            <button class="w-full text-left p-3 rounded text-xs font-bold text-gray-300">📄 INCIDENT REPORT (CASE)</button>
            <button class="w-full text-left p-3 rounded text-xs font-bold text-gray-300">⚖️ INTERNAL AFFAIRS FILING</button>
            <button class="w-full text-left p-3 rounded text-xs font-bold text-gray-300">🚫 SEARCH WARRANT REQ.</button>
        </aside>

        <main class="flex-1 p-8 overflow-y-auto flex flex-col items-center justify-center bg-[#e0e0e0] relative">
            
            <div class="z-50 bg-white/80 lock-blur p-12 rounded-lg border-2 border-dashed border-gray-400 shadow-2xl flex flex-col items-center text-center max-w-xl">
                <div class="bg-yellow-600 p-4 rounded-full mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>

                <h2 class="text-2xl font-black text-black uppercase tracking-tight mb-2">
                    Section Locked
                </h2>
                <p class="text-lg font-bold text-gray-800 italic mb-1">
                    "King Cox has this section locked. Please check again shortly!"
                </p>
                <p class="text-xs text-gray-500 font-mono mb-8 uppercase tracking-widest">
                    Reason: Issue with our API will be resolved later on.
                </p>

                <div class="flex gap-4">
                    <a href="/" class="bg-black text-white px-8 py-3 rounded font-black text-xs uppercase tracking-widest hover:bg-yellow-600 hover:text-black transition-all shadow-lg">
                        Go Back Home
                    </a>
                </div>
            </div>

            <div class="absolute inset-0 opacity-5 flex items-center justify-center pointer-events-none">
                <span class="text-[150px] font-black rotate-12">LOCKED</span>
            </div>

        </main>
    </div>

</body>
</html>
