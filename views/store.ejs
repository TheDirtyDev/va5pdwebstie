<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Virginia FivePD | Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        .glow-bg { background: radial-gradient(circle at 50% -20%, #1e3a8a 0%, #0b0f1a 45%); }
        .price-tag { clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0% 30%); }
        [x-text] { transition: all 0.3s ease; }
        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;  
            overflow: hidden;
        }
    </style>
</head>
<body class="bg-[#0b0f1a] text-white font-sans glow-bg min-h-screen" 
    x-data="{ 
        activeFilter: 'All', 
        currency: 'USD',
        rates: { USD: 1, GBP: 0.79, EUR: 0.92 },
        symbols: { USD: '$', GBP: '£', EUR: '€' },
        convert(price) {
            return this.symbols[this.currency] + (price * this.rates[this.currency]).toFixed(2);
        },
        policyOpen: false
    }">

    <%- include('partials/nav') %>

    <div class="max-w-7xl mx-auto py-16 px-6">
        
        <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
            <div>
                <h2 class="text-6xl font-black italic uppercase tracking-tighter leading-none">
                    Server <span class="text-blue-500">Store</span>
                </h2>
                <p class="text-gray-500 uppercase text-xs tracking-[0.4em] mt-2">Acquire premium permissions & equipment</p>
            </div>
            
            <div class="flex flex-col md:flex-row gap-4 items-center">
                <button @click="policyOpen = !policyOpen" 
                    class="bg-[#161b2c] hover:bg-blue-600 border border-white/5 px-6 py-3 rounded-2xl font-black uppercase tracking-widest text-[10px] transition-all flex items-center gap-3 shadow-lg">
                    <span x-text="policyOpen ? 'Close Protocols' : 'Policies & Refunds'"></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform duration-300" :class="policyOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>

                <div class="flex bg-[#161b2c] p-1 rounded-xl border border-white/5 shadow-xl">
                    <template x-for="(rate, cur) in rates">
                        <button @click="currency = cur" 
                            :class="currency === cur ? 'bg-blue-600 text-white' : 'text-gray-500 hover:text-white'"
                            class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all"
                            x-text="cur">
                        </button>
                    </template>
                </div>

                <% if (user && user.id === owner) { %>
                    <button onclick="document.getElementById('adminStoreBox').classList.toggle('hidden')" class="bg-blue-600 hover:bg-blue-500 px-8 py-3 rounded-2xl font-black uppercase tracking-widest text-xs transition-all shadow-[0_10px_30px_rgba(37,99,235,0.3)] active:scale-95">
                        + Create Product
                    </button>
                <% } %>
            </div>
        </div>

        <div x-show="policyOpen" 
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0 max-h-0"
             x-transition:enter-end="opacity-100 max-h-[1500px]"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100 max-h-[1500px]"
             x-transition:leave-end="opacity-0 max-h-0"
             class="overflow-hidden mb-12">
            <div class="p-10 bg-[#161b2c]/60 backdrop-blur-xl rounded-[2.5rem] border border-blue-500/20 relative shadow-2xl">
                <button @click="policyOpen = false" class="absolute top-8 right-8 text-gray-500 hover:text-white transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>

                <h3 class="text-blue-500 font-black uppercase text-sm tracking-[0.3em] mb-8 italic">VA5PD Store Protocols</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                    <div>
                        <h4 class="text-white font-black uppercase text-[10px] tracking-widest mb-3 opacity-50">General Conduct</h4>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            Upon purchase, donations do not grant the right to break in-game or Discord rules. At any time, we reserve the right to remove donor perks or packs if they are abused, without refund. If you receive a permanent ban, no refunds will be issued.
                        </p>
                    </div>
                    <div>
                        <h4 class="text-white font-black uppercase text-[10px] tracking-widest mb-3 opacity-50">Refund & Dispute Policy</h4>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            We do not offer refunds. Any attempt to charge back or file a payment dispute through a payment platform will result in a global ban from the <span class="text-blue-400">VA5PD</span> community.
                        </p>
                    </div>
                    <div>
                        <h4 class="text-white font-black uppercase text-[10px] tracking-widest mb-3 opacity-50">Asset Recovery</h4>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            If you leave Discord and later return, you may reclaim any packs you previously purchased one time. To do so, please open a ticket and request Store Management.
                        </p>
                    </div>
                    <div>
                        <h4 class="text-white font-black uppercase text-[10px] tracking-widest mb-3 opacity-50">Transaction Security</h4>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            All payments must be completed within a ticket with either an Owner or a trusted Store Team member. Any unverified or unauthorized purchases will be considered invalid. We do not allow reselling or trading of packs or perks.
                        </p>
                    </div>
                </div>

                <div class="mt-10 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">By purchasing, you automatically agree to the VA5PD terms.</p>
                    <a href="#" @click.prevent="alert('Please open a ticket to request the signed PDF version.')" class="text-blue-500 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors">Request Detailed Copy (Signed) &rarr;</a>
                </div>
            </div>
        </div>

        <div class="flex flex-wrap gap-4 mb-16 bg-[#161b2c]/40 backdrop-blur-md p-4 rounded-[2rem] border border-white/5">
            <button @click="activeFilter = 'All'" 
                :class="activeFilter === 'All' ? 'bg-blue-600 text-white' : 'bg-white/5 text-gray-400 hover:bg-white/10'"
                class="px-8 py-3 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] transition-all">
                All Archives
            </button>
            <% const uniqueCategories = [...new Set(items.map(item => item.category))].filter(c => c); 
               uniqueCategories.forEach(cat => { %>
                <button @click="activeFilter = '<%= cat %>'" 
                    :class="activeFilter === '<%= cat %>' ? 'bg-blue-600 text-white' : 'bg-white/5 text-gray-400 hover:bg-white/10'"
                    class="px-8 py-3 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] transition-all">
                    <%= cat %>
                </button>
            <% }) %>
        </div>

        <div id="adminStoreBox" class="hidden mb-16 bg-[#161b2c]/80 backdrop-blur-xl p-10 rounded-[2.5rem] border border-blue-500/30 shadow-2xl">
            <h3 class="text-blue-500 font-black uppercase text-xs tracking-widest mb-6">New Asset Protocol</h3>
            <form action="/store/add" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <input type="text" name="title" placeholder="Product Name" required class="bg-[#0b0f1a] border border-white/5 p-4 rounded-xl outline-none focus:border-blue-500 transition-all font-bold">
                <input type="text" name="category" placeholder="Category" required class="bg-[#0b0f1a] border border-white/5 p-4 rounded-xl outline-none focus:border-blue-500 transition-all font-bold">
                <input type="number" step="0.01" name="price" placeholder="Price ($)" required class="bg-[#0b0f1a] border border-white/5 p-4 rounded-xl outline-none focus:border-blue-500 transition-all font-bold">
                <input type="text" name="image" placeholder="Cover Image URL" class="bg-[#0b0f1a] border border-white/5 p-4 rounded-xl outline-none focus:border-blue-500 transition-all font-bold text-xs">
                <textarea name="description" placeholder="Technical Specifications..." class="bg-[#0b0f1a] border border-white/5 p-4 rounded-xl outline-none focus:border-blue-500 transition-all md:col-span-2"></textarea>
                <div class="flex items-center gap-3 md:col-span-2 px-2">
                    <input type="checkbox" name="is_announcement" id="is_ann" value="1" class="w-5 h-5 accent-blue-600">
                    <label for="is_ann" class="text-xs font-black uppercase text-gray-500 tracking-widest">Mark as Featured Asset</label>
                </div>
                <button type="submit" class="md:col-span-2 bg-white text-black py-5 rounded-2xl font-black uppercase tracking-[0.2em] text-sm hover:bg-blue-500 hover:text-white transition-all">Publish to Marketplace</button>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% items.forEach(item => { %>
                <div x-show="activeFilter === 'All' || activeFilter === '<%= item.category %>'" 
                     x-transition.duration.500ms
                     x-data="{ editing: false, expanded: false, isLong: <%= item.description.length > 150 %> }" 
                     class="relative bg-[#161b2c]/40 backdrop-blur-md rounded-[2.5rem] overflow-hidden border border-white/5 flex flex-col group transition-all hover:border-white/10 hover:translate-y-[-5px] <%= item.is_announcement ? 'md:col-span-3' : '' %>">
                    
                    <% if (item.sale_price) { %>
                        <div class="absolute top-6 left-6 z-10 bg-red-600 text-white text-[9px] font-black px-4 py-1.5 rounded-full uppercase italic tracking-tighter animate-pulse">Active Discount</div>
                    <% } %>

                    <% if (user && user.id === owner) { %>
                        <div class="absolute top-6 right-6 z-20 flex gap-2">
                            <button @click="editing = !editing" class="bg-[#0b0f1a]/80 backdrop-blur-md p-3 rounded-xl text-blue-400 hover:bg-blue-600 hover:text-white transition-all shadow-xl">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
                            </button>
                            <a href="/store/delete/<%= item.id %>" onclick="return confirm('Purge asset?')" class="bg-[#0b0f1a]/80 backdrop-blur-md p-3 rounded-xl text-red-500 hover:bg-red-600 hover:text-white transition-all shadow-xl">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            </a>
                        </div>
                    <% } %>

                    <div x-show="editing" class="p-8 bg-[#0b0f1a] h-full border-b border-white/5">
                        <form action="/store/edit/<%= item.id %>" method="POST" class="grid grid-cols-2 gap-4">
                            <input type="text" name="title" value="<%= item.title %>" class="bg-white/5 p-3 rounded-xl text-xs font-bold border border-white/10" placeholder="Product Name">
                            <input type="text" name="category" value="<%= item.category %>" class="bg-white/5 p-3 rounded-xl text-xs font-bold border border-white/10" placeholder="Category">
                            <input type="number" step="0.01" name="price" value="<%= item.price %>" class="bg-white/5 p-3 rounded-xl text-xs font-bold border border-white/10 text-blue-400">
                            <input type="number" step="0.01" name="sale_price" value="<%= item.sale_price %>" placeholder="Sale Price" class="bg-white/5 p-3 rounded-xl text-xs font-bold border border-white/10 text-emerald-400">
                            <input type="text" name="image" value="<%= item.image %>" class="bg-white/5 p-3 rounded-xl text-xs font-bold border border-white/10 col-span-2" placeholder="Image URL">
                            <textarea name="description" class="bg-white/5 p-3 rounded-xl text-xs col-span-2 border border-white/10" rows="4"><%= item.description %></textarea>
                            <button type="submit" class="bg-blue-600 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest">Update Archive</button>
                            <button type="button" @click="editing = false" class="bg-white/10 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest">Discard</button>
                        </form>
                    </div>

                    <div class="<%= item.is_announcement ? 'flex flex-col md:flex-row h-full' : '' %>" x-show="!editing">
                        <div class="<%= item.is_announcement ? 'md:w-3/5' : 'h-64' %> overflow-hidden relative">
                            <img src="<%= item.image %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                            <div class="absolute inset-0 bg-gradient-to-t from-[#161b2c] via-transparent opacity-80"></div>
                        </div>

                        <div class="p-10 flex flex-col justify-between flex-grow">
                            <div>
                                <span class="text-[10px] font-black uppercase text-blue-500 tracking-[0.3em] mb-3 block"><%= item.category %></span>
                                <h3 class="<%= item.is_announcement ? 'text-5xl' : 'text-3xl' %> font-black italic uppercase tracking-tighter mb-4"><%= item.title %></h3>
                                
                                <div class="relative">
                                    <p class="text-gray-400 text-sm leading-relaxed transition-all duration-300" 
                                       :class="expanded ? '' : 'line-clamp-3'"><%= item.description %></p>
                                    
                                    <template x-if="isLong">
                                        <button @click="expanded = !expanded" 
                                                class="text-blue-500 text-[10px] font-black uppercase tracking-widest mt-2 hover:text-blue-400 transition-colors flex items-center gap-1">
                                            <span x-text="expanded ? 'Read Less -' : 'Read More +'"></span>
                                        </button>
                                    </template>
                                </div>
                            </div>

                            <div class="mt-8">
                                <div class="flex items-center gap-4 mb-8">
                                    <div class="bg-blue-600 text-white px-6 py-2 font-mono font-black italic text-2xl price-tag shadow-[0_5px_15px_rgba(37,99,235,0.4)]"
                                         x-text="convert(<%= item.sale_price || item.price %>)">
                                    </div>
                                    <% if (item.sale_price) { %>
                                        <span class="text-gray-600 line-through font-mono font-bold" x-text="convert(<%= item.price %>)"></span>
                                    <% } %>
                                </div>
                                <a href="<%= ticketUrl %>" target="_blank" class="block w-full text-center bg-white text-black py-4 rounded-2xl font-black uppercase tracking-[0.2em] text-[10px] hover:bg-blue-600 hover:text-white transition-all shadow-xl active:scale-95">
                                    Open Store Ticket
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>
