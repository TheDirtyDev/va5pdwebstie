<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>VA5PD | Owner Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0b0f1a; color: white; }
        .signature-font { font-family: 'Dancing Script', cursive; }
        #modalContent::-webkit-scrollbar, #onboardingContent::-webkit-scrollbar { width: 6px; }
        #modalContent::-webkit-scrollbar-track, #onboardingContent::-webkit-scrollbar-track { background: #161b2c; }
        #modalContent::-webkit-scrollbar-thumb, #onboardingContent::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
        .item-row, .tool-card { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        .glass-effect { background: rgba(22, 27, 44, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
    </style>
</head>

<body class="bg-[#0b0f1a] text-white font-sans">
    <%- include('partials/nav') %>

    <div class="max-w-7xl mx-auto py-12 px-6">
        <div class="mb-10 flex justify-between items-end">
            <div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter">Owner <span class="text-blue-500">Command Center</span></h1>
                <p class="text-gray-500">System Status: <span class="text-emerald-500 font-bold">OPERATIONAL</span></p>
            </div>
            <div class="text-right hidden md:block">
                <p class="text-[10px] font-black text-gray-600 uppercase tracking-widest">Server Time</p>
                <p class="text-lg font-mono text-gray-400" id="serverClock">00:00:00</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="bg-[#161b2c] p-8 rounded-3xl border border-gray-800 shadow-xl relative overflow-hidden group hover:border-cyan-500/50 transition-colors">
                <div class="absolute -right-4 -top-4 text-cyan-500/10 group-hover:text-cyan-500/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                </div>
                <p class="text-cyan-500 uppercase text-[10px] font-black tracking-widest mb-1">Total Updates</p>
                <h3 class="text-5xl font-black tabular-nums"><%= adminPanelData.stats.updates %></h3>
            </div>

            <div class="bg-[#161b2c] p-8 rounded-3xl border border-gray-800 shadow-xl relative overflow-hidden group hover:border-amber-500/50 transition-colors">
                <div class="absolute -right-4 -top-4 text-amber-500/10 group-hover:text-amber-500/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <p class="text-amber-500 uppercase text-[10px] font-black tracking-widest mb-1">Active Users</p>
                <h3 class="text-5xl font-black tabular-nums"><%= adminPanelData.stats.activeUsers %></h3>
            </div>

            <div class="bg-[#161b2c] p-8 rounded-3xl border border-gray-800 shadow-xl relative overflow-hidden group hover:border-emerald-500/50 transition-colors">
                <div class="absolute -right-4 -top-4 text-emerald-500/10 group-hover:text-emerald-500/20 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <p class="text-emerald-500 uppercase text-[10px] font-black tracking-widest mb-1">Store Items</p>
                <h3 class="text-5xl font-black tabular-nums"><%= adminPanelData.stats.items %></h3>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-4">
                <h4 class="text-xs font-black uppercase tracking-widest text-gray-500 px-2">Core Management</h4>
                <a href="/updates" class="flex items-center justify-between bg-[#161b2c] p-6 rounded-2xl border border-gray-800 hover:border-blue-500 transition group shadow-lg">
                    <span class="font-bold uppercase italic group-hover:text-blue-400">Dev Log Manager</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-600 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="/store" class="flex items-center justify-between bg-[#161b2c] p-6 rounded-2xl border border-gray-800 hover:border-blue-500 transition group shadow-lg">
                    <span class="font-bold uppercase italic group-hover:text-blue-400">Store Front Office</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-600 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>

            <div class="lg:col-span-1">
                <h4 class="text-xs font-black uppercase tracking-widest text-gray-500 px-2 mb-4">Operations Toolbox</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <button onclick="toggleReceiptModal()" class="text-left group relative bg-[#161b2c] border border-gray-800 rounded-3xl p-6 hover:border-red-500/50 transition-all duration-300 overflow-hidden shadow-2xl">
                        <div class="absolute -right-2 -bottom-2 w-24 h-24 bg-red-600/10 blur-3xl group-hover:bg-red-600/20 transition-colors"></div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div class="bg-red-500/10 text-red-500 w-12 h-12 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                            </div>
                            <div>
                                <h5 class="text-lg font-black uppercase italic tracking-tight group-hover:text-red-400">Receipt Gen</h5>
                                <p class="text-xs text-gray-500 font-medium">Financial Transaction PDF</p>
                            </div>
                        </div>
                    </button>

                    <button onclick="toggleOnboardingModal()" class="text-left group relative bg-[#161b2c] border border-gray-800 rounded-3xl p-6 hover:border-blue-500/50 transition-all duration-300 overflow-hidden shadow-2xl">
                        <div class="absolute -right-2 -bottom-2 w-24 h-24 bg-blue-600/10 blur-3xl group-hover:bg-blue-600/20 transition-colors"></div>
                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div class="bg-blue-500/10 text-blue-500 w-12 h-12 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.826L10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 10-5.656-5.656l-1.102 1.101" />
                                </svg>
                            </div>
                            <div>
                                <h5 class="text-lg font-black uppercase italic tracking-tight group-hover:text-blue-400">Dev Link Gen</h5>
                                <p class="text-xs text-gray-500 font-medium">One-Time Policy Invite</p>
                            </div>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="receiptModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/95 backdrop-blur-md p-4">
        <div class="bg-[#161b2c] border border-gray-800 w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden max-h-[90vh] flex flex-col">
            <div class="p-8 border-b border-gray-800 flex justify-between items-center bg-[#1c2237]">
                <div>
                    <h3 class="text-2xl font-black italic uppercase tracking-tighter">Receipt <span class="text-red-500">Creator</span></h3>
                    <p class="text-[10px] text-gray-400 uppercase tracking-[0.2em] mt-1 font-bold">Financial Module</p>
                </div>
                <button onclick="toggleReceiptModal()" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 text-gray-400 hover:text-white hover:bg-red-500 transition-all text-2xl">&times;</button>
            </div>
            <div id="modalContent" class="p-8 overflow-y-auto space-y-8 flex-1">
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Authorized Handler</label>
                        <input type="text" id="pdfHandler" value="Captain" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-xl p-3 text-sm outline-none focus:border-red-500 transition-colors">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Payment Method</label>
                        <select id="pdfCard" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-xl p-3 text-sm outline-none focus:border-red-500 transition-colors">
                            <option>Visa</option><option>Mastercard</option><option>Cash App</option><option>Store Credit</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Recipient Email</label>
                    <input type="email" id="pdfEmail" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-xl p-3 text-sm outline-none focus:border-blue-500 transition-colors">
                </div>
                <div class="space-y-4">
                    <div class="flex justify-between items-center border-b border-gray-800 pb-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Purchase Details</label>
                        <button onclick="addItemRow()" class="text-[10px] bg-blue-600/10 text-blue-400 border border-blue-500/20 px-4 py-1.5 rounded-full font-black hover:bg-blue-600 hover:text-white transition-all uppercase">+ Add Item</button>
                    </div>
                    <div id="itemsContainer" class="space-y-3">
                        <div class="item-row grid grid-cols-12 gap-4 items-center bg-[#0b0f1a]/50 p-4 rounded-2xl border border-gray-800/50">
                            <div class="col-span-7"><input type="text" placeholder="Item Name" class="item-desc w-full bg-transparent text-sm font-bold outline-none border-b border-transparent focus:border-gray-700"></div>
                            <div class="col-span-4 border-l border-gray-800 pl-4"><span class="text-xs text-gray-600 mr-1">$</span><input type="number" placeholder="0.00" class="item-price w-full bg-transparent text-sm font-mono outline-none"></div>
                            <button onclick="this.parentElement.remove()" class="col-span-1 text-gray-700 hover:text-red-500 transition-colors text-xl">&times;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-8 bg-[#1c2237] border-t border-gray-800 grid grid-cols-2 gap-4">
                <button onclick="handleReceiptAction('download')" class="w-full bg-gray-700 hover:bg-gray-600 text-white font-black uppercase py-5 rounded-2xl transition-all">Download</button>
                <button id="emailBtn" onclick="handleReceiptAction('email')" class="w-full bg-red-600 hover:bg-red-500 text-white font-black uppercase py-5 rounded-2xl transition-all">Send Email</button>
            </div>
        </div>
    </div>

    <div id="onboardingModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/95 backdrop-blur-md p-4">
        <div class="bg-[#161b2c] border border-gray-800 w-full max-w-xl rounded-[2.5rem] shadow-2xl overflow-hidden flex flex-col">
            <div class="p-8 border-b border-gray-800 flex justify-between items-center bg-[#1c2237]">
                <div>
                    <h3 class="text-2xl font-black italic uppercase tracking-tighter">Recruit <span class="text-blue-500">Onboarding</span></h3>
                    <p class="text-[10px] text-gray-400 uppercase tracking-[0.2em] mt-1 font-bold">Secure Policy Link Generator</p>
                </div>
                <button onclick="toggleOnboardingModal()" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 text-gray-400 hover:text-white hover:bg-blue-500 transition-all text-2xl">&times;</button>
            </div>
            
            <div class="p-10 space-y-6">
                <div class="p-6 bg-blue-500/5 border border-blue-500/20 rounded-2xl">
                    <p class="text-xs text-blue-400 font-bold mb-2 uppercase tracking-widest">Instructions</p>
                    <p class="text-sm text-gray-400 leading-relaxed">This tool generates a unique, one-time link for new developers. The link expires in <span class="text-white font-bold">2 hours</span>. Once signed, the legal document is logged and sent to Discord.</p>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Generated Invite Link</label>
                    <div class="relative">
                        <input type="text" id="generatedInviteUrl" readonly placeholder="Click Generate Below..." 
                            class="w-full bg-[#0b0f1a] border border-gray-800 rounded-xl p-4 text-sm font-mono text-blue-400 outline-none">
                        <button onclick="copyInviteLink()" class="absolute right-2 top-2 bottom-2 px-4 bg-gray-800 hover:bg-gray-700 rounded-lg text-[10px] font-black uppercase transition-all">Copy</button>
                    </div>
                </div>

                <div id="genStatus" class="text-center py-2 hidden">
                    <span class="text-[10px] font-black text-emerald-500 uppercase tracking-widest animate-pulse">Link active and ready for recruit</span>
                </div>

                <button id="generateBtn" onclick="generateOnboardingLink()" 
                    class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black uppercase tracking-[0.2em] py-5 rounded-2xl shadow-xl shadow-blue-900/20 transition-all active:scale-[0.97]">
                    Generate Invite Link
                </button>
            </div>
        </div>
    </div>

    <script>
        // -- CLOCK --
        setInterval(() => {
            document.getElementById('serverClock').innerText = new Date().toLocaleTimeString();
        }, 1000);

        // -- MODAL TOGGLES --
        function toggleReceiptModal() { document.getElementById('receiptModal').classList.toggle('hidden'); }
        function toggleOnboardingModal() { 
            document.getElementById('onboardingModal').classList.toggle('hidden'); 
            document.getElementById('generatedInviteUrl').value = "";
            document.getElementById('genStatus').classList.add('hidden');
        }

        // -- ONBOARDING LOGIC --
        async function generateOnboardingLink() {
            const btn = document.getElementById('generateBtn');
            const input = document.getElementById('generatedInviteUrl');
            const status = document.getElementById('genStatus');

            btn.innerText = "GENERATING TOKEN...";
            btn.disabled = true;

            try {
                const response = await fetch('/admin/generate-onboarding');
                const data = await response.json();

                if (data.url) {
                    input.value = data.url;
                    status.classList.remove('hidden');
                    btn.innerText = "REGENERATE LINK";
                } else {
                    alert("Error: " + (data.error || "Unknown error"));
                }
            } catch (err) {
                alert("Server Unreachable");
            } finally {
                btn.disabled = false;
            }
        }

        function copyInviteLink() {
            const input = document.getElementById('generatedInviteUrl');
            if (!input.value) return;
            input.select();
            document.execCommand('copy');
            alert("Invite Link Copied to Clipboard!");
        }

        // -- RECEIPT LOGIC --
        function addItemRow() {
            const container = document.getElementById('itemsContainer');
            const row = document.createElement('div');
            row.className = 'item-row grid grid-cols-12 gap-4 items-center bg-[#0b0f1a]/50 p-4 rounded-2xl border border-gray-800/50';
            row.innerHTML = `
                <div class="col-span-7"><input type="text" placeholder="Item Name" class="item-desc w-full bg-transparent text-sm font-bold outline-none border-b border-transparent focus:border-gray-700"></div>
                <div class="col-span-4 border-l border-gray-800 pl-4"><span class="text-xs text-gray-600 mr-1">$</span><input type="number" placeholder="0.00" class="item-price w-full bg-transparent text-sm font-mono outline-none"></div>
                <button onclick="this.parentElement.remove()" class="col-span-1 text-gray-700 hover:text-red-500 transition-colors text-xl font-light">&times;</button>
            `;
            container.appendChild(row);
        }

        async function handleReceiptAction(type) {
            const { jsPDF } = window.jspdf;
            const handler = document.getElementById('pdfHandler').value;
            const card = document.getElementById('pdfCard').value;
            const email = document.getElementById('pdfEmail').value;
            const rows = document.querySelectorAll('.item-row');
            
            let tableData = [];
            let subtotal = 0;

            rows.forEach(row => {
                const desc = row.querySelector('.item-desc').value || "Item";
                const price = parseFloat(row.querySelector('.item-price').value) || 0;
                tableData.push([desc, `$${price.toFixed(2)}`]);
                subtotal += price;
            });

            if (type === 'download') {
                const doc = new jsPDF();
                doc.setFontSize(22);
                doc.text("VA5PD NETWORK RECEIPT", 105, 20, { align: 'center' });
                doc.autoTable({ startY: 40, head: [['Description', 'Amount']], body: tableData });
                doc.save(`VA5PD-Receipt.pdf`);
            } else {
                // Email Fetch Logic (Same as your previous version)
                alert("Sending to: " + email);
            }
        }
    </script>
</body>
</html>
