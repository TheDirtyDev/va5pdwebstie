<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VA5PD | Management Terminal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

    <style>
        :root { --bg-dark: #0b0f1a; --card-bg: #161b2c; --accent-blue: #3b82f6; --accent-red: #ef4444; }
        body { font-family: 'Inter', sans-serif; background-color: var(--bg-dark); color: white; margin: 0; overflow-x: hidden; }
        .signature-font { font-family: 'Dancing Script', cursive; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0b0f1a; }
        ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #374151; }

        .glass-panel { background: rgba(22, 27, 44, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .hero-gradient { background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.15), transparent); }
        
        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .animate-slide { animation: slideUp 0.5s ease forwards; }
    </style>
</head>
<body class="hero-gradient min-h-screen">

    <nav class="border-b border-gray-800 bg-[#0b0f1a]/80 backdrop-blur-md sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center font-black italic shadow-lg shadow-blue-900/20">VA</div>
                <span class="font-black uppercase tracking-tighter text-xl italic">FivePD <span class="text-blue-500 underline decoration-2 underline-offset-4">Network</span></span>
            </div>
            <div class="flex gap-6 text-xs font-bold uppercase tracking-widest text-gray-400">
                <a href="#" class="hover:text-white transition">Dashboard</a>
                <a href="#" class="hover:text-white transition">Server Logs</a>
                <a href="#" class="text-blue-500">Management</a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-6">
        <div class="mb-12 animate-slide">
            <h1 class="text-5xl font-black italic uppercase tracking-tighter mb-2">Command <span class="text-blue-500">Terminal</span></h1>
            <p class="text-gray-500 font-medium">Authorized Personnel Only • Session Active: <%= new Date().toLocaleTimeString() %></p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12 animate-slide" style="animation-delay: 0.1s;">
            <div class="glass-panel p-6 rounded-3xl relative overflow-hidden">
                <div class="text-[10px] uppercase font-black text-blue-500 mb-1">Total Transactions</div>
                <div class="text-3xl font-black italic tabular-nums">1,284</div>
                <div class="absolute -right-4 -bottom-4 opacity-5 text-blue-500"><svg width="80" height="80" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div>
            </div>
            <div class="glass-panel p-6 rounded-3xl relative overflow-hidden">
                <div class="text-[10px] uppercase font-black text-emerald-500 mb-1">Active Developers</div>
                <div class="text-3xl font-black italic tabular-nums">12</div>
            </div>
            <div class="glass-panel p-6 rounded-3xl relative overflow-hidden">
                <div class="text-[10px] uppercase font-black text-amber-500 mb-1">Pending Onboarding</div>
                <div class="text-3xl font-black italic tabular-nums">3</div>
            </div>
            <div class="glass-panel p-6 rounded-3xl relative overflow-hidden">
                <div class="text-[10px] uppercase font-black text-red-500 mb-1">System Health</div>
                <div class="text-3xl font-black italic tabular-nums uppercase">Stable</div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 animate-slide" style="animation-delay: 0.2s;">
            
            <div class="space-y-6">
                <div class="flex items-center gap-2 px-2">
                    <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                    <h2 class="text-xs font-black uppercase tracking-[0.3em] text-gray-500">Financial Control</h2>
                </div>
                
                <button onclick="toggleModal('receiptModal')" class="w-full text-left group glass-panel p-8 rounded-[2.5rem] hover:border-red-500/50 transition-all duration-500 shadow-2xl">
                    <div class="flex justify-between items-start mb-6">
                        <div class="bg-red-500/10 text-red-500 p-4 rounded-2xl group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <div class="text-[10px] font-black bg-white/5 px-3 py-1 rounded-full uppercase tracking-tighter">v2.4 Stable</div>
                    </div>
                    <h3 class="text-2xl font-black uppercase italic italic group-hover:text-red-400 transition-colors">Receipt Generator</h3>
                    <p class="text-gray-500 text-sm mt-2 leading-relaxed">Create and export official digital transaction receipts. Supports multi-item billing and tax calculations.</p>
                </button>
            </div>

            <div class="space-y-6">
                <div class="flex items-center gap-2 px-2">
                    <div class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></div>
                    <h2 class="text-xs font-black uppercase tracking-[0.3em] text-gray-500">Personnel & Legal</h2>
                </div>

                <button onclick="toggleModal('policyModal')" class="w-full text-left group glass-panel p-8 rounded-[2.5rem] hover:border-blue-500/50 transition-all duration-500 shadow-2xl">
                    <div class="flex justify-between items-start mb-6">
                        <div class="bg-blue-500/10 text-blue-500 p-4 rounded-2xl group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </div>
                        <div class="text-[10px] font-black bg-white/5 px-3 py-1 rounded-full uppercase tracking-tighter">Legal Compliant</div>
                    </div>
                    <h3 class="text-2xl font-black uppercase italic italic group-hover:text-blue-400 transition-colors">Policy Recruitment</h3>
                    <p class="text-gray-500 text-sm mt-2 leading-relaxed">Generate secure, one-time invitation links for trial developers to sign the Server Development Policy.</p>
                </button>
            </div>
        </div>
    </main>

    <div id="receiptModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/95 backdrop-blur-md p-4">
        <div class="bg-[#161b2c] border border-gray-800 w-full max-w-2xl rounded-[3rem] shadow-2xl overflow-hidden flex flex-col max-h-[95vh]">
            <div class="p-8 border-b border-gray-800 flex justify-between items-center bg-[#1c2237]">
                <div>
                    <h3 class="text-2xl font-black italic uppercase italic">Receipt <span class="text-red-500">Creator</span></h3>
                    <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest">Official Transaction Export</p>
                </div>
                <button onclick="toggleModal('receiptModal')" class="text-3xl text-gray-500 hover:text-white transition-colors">&times;</button>
            </div>

            <div class="p-8 overflow-y-auto space-y-6 flex-1 bg-[#0b0f1a]/30">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Authorized Handler</label>
                        <input type="text" id="pdfHandler" value="Koldin" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-2xl p-4 text-sm font-bold focus:border-red-500 outline-none transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Payment Method</label>
                        <select id="pdfMethod" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-2xl p-4 text-sm font-bold focus:border-red-500 outline-none transition-all appearance-none">
                            <option>Cash App</option>
                            <option>Venmo</option>
                            <option>PayPal</option>
                            <option>Store Credit</option>
                            <option>Debit/Credit</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Items to Invoice</label>
                        <button onclick="addItemRow()" class="text-[10px] bg-red-500/10 text-red-500 px-4 py-1.5 rounded-full font-black uppercase hover:bg-red-500 hover:text-white transition-all">+ Add Item</button>
                    </div>
                    <div id="itemsContainer" class="space-y-3">
                        <div class="item-row grid grid-cols-12 gap-3 bg-[#0b0f1a] p-4 rounded-2xl border border-gray-800 shadow-inner">
                            <div class="col-span-8">
                                <input type="text" placeholder="Item Name (e.g. Custom Plate)" class="item-desc w-full bg-transparent text-sm font-bold outline-none">
                            </div>
                            <div class="col-span-3 border-l border-gray-800 pl-3">
                                <span class="text-xs text-gray-600 mr-1">$</span>
                                <input type="number" placeholder="0.00" class="item-price w-full bg-transparent text-sm font-mono outline-none">
                            </div>
                            <button onclick="this.parentElement.remove()" class="col-span-1 text-red-500 hover:scale-125 transition-transform">&times;</button>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6 pt-6 border-t border-gray-800">
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">Tax Rate (%)</label>
                        <input type="number" id="pdfTax" value="7" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-2xl p-4 text-sm font-mono focus:border-red-500 outline-none transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] uppercase font-black text-gray-500 ml-1">E-Signature</label>
                        <input type="text" id="pdfSignature" placeholder="Print Name" class="w-full bg-[#0b0f1a] border border-gray-800 rounded-2xl p-4 text-2xl text-red-500 outline-none signature-font transition-all placeholder:text-red-900/30">
                    </div>
                </div>
            </div>

            <div class="p-8 bg-[#1c2237] border-t border-gray-800">
                <button onclick="handleReceiptAction('download')" class="w-full bg-red-600 hover:bg-red-500 text-white font-black uppercase tracking-[0.2em] py-6 rounded-2xl shadow-xl shadow-red-900/20 active:scale-[0.98] transition-all">Generate & Download PDF</button>
            </div>
        </div>
    </div>

    <div id="policyModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/95 backdrop-blur-md p-4">
        <div class="bg-[#161b2c] border border-gray-800 w-full max-w-xl rounded-[3rem] shadow-2xl flex flex-col">
            <div class="p-8 border-b border-gray-800 flex justify-between items-center bg-[#1c2237]">
                <h3 class="text-2xl font-black italic uppercase italic">Policy <span class="text-blue-500 font-black">Gen</span></h3>
                <button onclick="toggleModal('policyModal')" class="text-3xl text-gray-500 hover:text-white transition-colors">&times;</button>
            </div>
            <div class="p-10 space-y-6">
                <div class="p-6 bg-blue-500/5 border border-blue-500/10 rounded-2xl">
                    <p class="text-[10px] text-blue-400 font-black uppercase tracking-widest mb-2 italic">Developer Onboarding</p>
                    <p class="text-xs text-gray-400 leading-relaxed">Generates a unique link for the <b>Server Development Policy</b>. The recruit must provide their First/Last name, Age, and Signature to gain access.</p>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] uppercase font-black text-gray-500">Recruitment Link</label>
                    <div class="relative group">
                        <input type="text" id="policyInviteUrl" readonly placeholder="Waiting for generation..." class="w-full bg-[#0b0f1a] border border-gray-800 rounded-2xl p-5 text-sm font-mono text-blue-400 outline-none">
                        <button onclick="copyToClipboard()" class="absolute right-3 top-3 bottom-3 px-4 bg-gray-800 hover:bg-gray-700 rounded-xl text-[10px] font-black uppercase transition-all">Copy</button>
                    </div>
                </div>
                <button onclick="generatePolicyLink()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black uppercase tracking-[0.2em] py-6 rounded-2xl shadow-xl shadow-blue-900/20 active:scale-[0.98] transition-all">Generate Invite Token</button>
            </div>
        </div>
    </div>

    <script>
        function toggleModal(id) { document.getElementById(id).classList.toggle('hidden'); }

        function addItemRow() {
            const container = document.getElementById('itemsContainer');
            const row = document.createElement('div');
            row.className = 'item-row grid grid-cols-12 gap-3 bg-[#0b0f1a] p-4 rounded-2xl border border-gray-800 shadow-inner animate-slide';
            row.innerHTML = `
                <div class="col-span-8"><input type="text" placeholder="Item Name" class="item-desc w-full bg-transparent text-sm font-bold outline-none"></div>
                <div class="col-span-3 border-l border-gray-800 pl-3"><span class="text-xs text-gray-600 mr-1">$</span><input type="number" placeholder="0.00" class="item-price w-full bg-transparent text-sm font-mono outline-none"></div>
                <button onclick="this.parentElement.remove()" class="col-span-1 text-red-500">&times;</button>`;
            container.appendChild(row);
        }

        async function generatePolicyLink() {
            const token = Math.random().toString(36).substring(2, 15);
            const input = document.getElementById('policyInviteUrl');
            input.value = `${window.location.origin}/onboard/${token}`;
            alert("Invite generated. Link will remain active for 2 hours.");
        }

        function copyToClipboard() {
            const input = document.getElementById('policyInviteUrl');
            if(!input.value) return;
            input.select();
            document.execCommand('copy');
            alert("Copied!");
        }

        async function handleReceiptAction(type) {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const handler = document.getElementById('pdfHandler').value || "Koldin";
            const method = document.getElementById('pdfMethod').value;
            const signature = document.getElementById('pdfSignature').value || "AUTHORIZED SIGNATURE";
            const taxRate = parseFloat(document.getElementById('pdfTax').value) || 7;
            const timestamp = new Date().toLocaleString();
            const invoiceID = `VA5PD-${Math.floor(100000 + Math.random() * 900000)}`;

            let subtotal = 0;
            const tableData = Array.from(document.querySelectorAll('.item-row')).map(row => {
                const desc = row.querySelector('.item-desc').value || "Service";
                const price = parseFloat(row.querySelector('.item-price').value) || 0;
                subtotal += price;
                return [desc, `$${price.toFixed(2)}`];
            });

            const taxAmount = subtotal * (taxRate / 100);
            const total = subtotal + taxAmount;

            // PDF CONSTRUCTION (Matches provided sample layout)
            doc.setFont("helvetica", "bold");
            doc.setFontSize(24);
            doc.text("VA5PD NETWORK", 105, 35, { align: 'center' });
            
            doc.setFontSize(10);
            doc.text("Official Digital Transaction Receipt", 105, 42, { align: 'center' });
            doc.text(`Invoice ID: ${invoiceID}`, 105, 47, { align: 'center' });

            doc.setFontSize(9);
            doc.setTextColor(100);
            doc.text(`TIMESTAMP: ${timestamp}`, 20, 60);
            doc.text(`Method: ${method}`, 150, 60);

            doc.setTextColor(0);
            doc.setFontSize(10);
            doc.text("BILLED BY:", 20, 75);
            doc.setFont("helvetica", "bold");
            doc.text("VA5PD Management Team", 20, 80);
            doc.setFont("helvetica", "normal");
            doc.text(`Handler: ${handler}`, 20, 85);

            doc.autoTable({
                startY: 95,
                head: [['Name of Items', 'Price']],
                body: tableData,
                theme: 'grid',
                headStyles: { fillColor: [11, 15, 26], textColor: [255, 255, 255] },
                styles: { fontSize: 10 }
            });

            const finalY = doc.lastAutoTable.finalY + 15;
            doc.text(`Subtotal:`, 140, finalY);
            doc.text(`$${subtotal.toFixed(2)}`, 180, finalY, { align: 'right' });
            doc.text(`Tax (${taxRate}%):`, 140, finalY + 7);
            doc.text(`$${taxAmount.toFixed(2)}`, 180, finalY + 7, { align: 'right' });
            
            doc.setFont("helvetica", "bold");
            doc.text(`GRAND TOTAL:`, 140, finalY + 14);
            doc.text(`$${total.toFixed(2)}`, 180, finalY + 14, { align: 'right' });

            // Signature Section
            doc.setFont("helvetica", "bold");
            doc.text(signature, 20, finalY + 14);
            doc.line(20, finalY + 16, 80, finalY + 16);
            doc.setFontSize(8);
            doc.text("AUTHORIZED SIGNATURE", 20, finalY + 21);

            doc.save(`VA5PD_Receipt_${Date.now()}.pdf`);
        }
    </script>
</body>
</html>
