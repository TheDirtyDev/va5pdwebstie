<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VA5PD | Status</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .glow-bg {
            background: radial-gradient(circle at 50% -20%, #1e3a8a 0%, #0b0f1a 45%);
        }
        .scanline {
            width: 100%;
            height: 2px;
            background: rgba(59, 130, 246, 0.1);
            position: absolute;
            animation: scan 4s linear infinite;
        }
        @keyframes scan {
            0% { top: 0; }
            100% { top: 100%; }
        }
    </style>
</head>
<body class="bg-[#0b0f1a] text-white font-sans glow-bg min-h-screen">

    <%- include('partials/nav') %>

    <div class="max-w-7xl mx-auto py-16 px-6">
        
        <div class="mb-12">
            <h1 class="text-5xl font-black italic uppercase tracking-tighter">Network <span class="text-blue-500">Status</span></h1>
            <p class="text-gray-500 uppercase text-xs tracking-[0.3em] mt-2">API SYSTEM / STATUS OF SERVER</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
            
            <div class="lg:col-span-2 bg-[#161b2c]/60 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5 shadow-2xl relative overflow-hidden flex flex-col md:flex-row justify-between items-center group">
                <div class="scanline"></div>
                
                <div class="flex items-center gap-8 z-10">
                    <% if (server.online) { %>
                        <div class="relative">
                            <div class="h-20 w-20 bg-emerald-500/10 rounded-3xl flex items-center justify-center border border-emerald-500/20 rotate-3 group-hover:rotate-12 transition-transform">
                                <div class="h-4 w-4 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_15px_#10b981]"></div>
                            </div>
                        </div>
                        <div>
                            <h2 class="text-3xl font-black uppercase italic tracking-tighter text-white drop-shadow-md">
                                <%= server.name %>
                            </h2>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="px-2 py-0.5 bg-emerald-500/10 text-emerald-500 text-[10px] font-black uppercase tracking-widest rounded border border-emerald-500/20">Virginia</span>
                                <span class="text-gray-500 text-[10px] font-mono uppercase">Uptime 99.3%</span>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="h-20 w-20 bg-red-500/10 rounded-3xl flex items-center justify-center border border-red-500/20">
                            <div class="h-4 w-4 bg-red-500 rounded-full shadow-[0_0_15px_#ef4444]"></div>
                        </div>
                        <div>
                            <h2 class="text-3xl font-black uppercase italic tracking-tighter text-red-500">System Offline</h2>
                            <p class="text-gray-500 text-xs font-black uppercase tracking-widest">Awaiting Reconnection...</p>
                        </div>
                    <% } %>
                </div>

                <div class="flex items-center gap-6 mt-8 md:mt-0 z-10">
                    <div class="text-right">
                        <p class="text-gray-500 text-[10px] uppercase font-black tracking-widest mb-1">Population</p>
                        <h3 class="text-4xl font-black italic tabular-nums">
                            <%= server.players.length %> <span class="text-blue-500/30 text-xl">/</span> <%= server.maxPlayers %>
                        </h3>
                    </div>
                    <a href="<%= server.joinUrl %>" class="bg-blue-600 hover:bg-blue-500 text-white px-10 py-4 rounded-2xl font-black transition-all shadow-[0_10px_30px_rgba(37,99,235,0.3)] uppercase italic tracking-tighter active:scale-95">
                        Deploy
                    </a>
                </div>
            </div>

            <div class="bg-blue-600 p-8 rounded-[2.5rem] shadow-2xl flex flex-col justify-center relative overflow-hidden group">
                <div class="absolute -right-4 -bottom-4 opacity-20 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <p class="text-blue-200 text-[10px] font-black uppercase tracking-[0.2em] mb-2">Network Manager</p>
                <h4 class="text-white text-4xl font-black italic leading-tight">VACORE<br>API</h4>
            </div>
        </div>

        <div class="bg-[#161b2c]/40 backdrop-blur-md rounded-[2.5rem] border border-white/5 overflow-hidden">
            <div class="px-10 py-6 border-b border-white/5 flex justify-between items-center bg-white/5">
                <h4 class="font-black text-gray-400 uppercase text-xs tracking-[0.2em]">Active Users</h4>
                <span class="text-[10px] font-mono text-blue-500 bg-blue-500/10 px-3 py-1 rounded-full border border-blue-500/20">LIVE FEED</span>
            </div>

            <div class="p-10">
                <% if (!server.online) { %>
                    <div class="text-center py-24">
                        <div class="text-6xl mb-4">📡</div>
                        <p class="text-gray-500 italic font-medium">Signal lost... Looking for connection!</p>
                    </div>
                <% } else if (server.players.length === 0) { %>
                    <div class="text-center py-24 border-2 border-dashed border-white/5 rounded-[2rem] group hover:border-blue-500/20 transition-colors">
                        <h5 class="text-4xl font-black text-white/10 uppercase italic group-hover:text-white/20 transition-colors">Server Empty</h5>
                        <p class="text-gray-600 text-sm mt-2 tracking-widest uppercase font-bold">No players currently on..</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                        <% server.players.forEach(player => { %>
                            <div class="bg-white/5 p-5 rounded-2xl border border-white/5 flex items-center gap-4 group hover:bg-blue-600 transition-all cursor-default">
                                <div class="bg-white/10 h-10 w-10 rounded-xl flex items-center justify-center text-xs font-black text-blue-400 group-hover:bg-white group-hover:text-blue-600 transition-all">
                                    <%= player.id %>
                                </div>
                                <div>
                                    <p class="font-black text-sm uppercase italic tracking-tight group-hover:text-white"><%= player.name %></p>
                                    <p class="text-[10px] text-gray-500 uppercase font-bold group-hover:text-blue-200">Active</p>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>
